# ─────────────────────────────────────────────────────
# WellTrack — Backend Environment Template
#
# INSTRUCTIONS:
#   cp backend/env.template backend/.env
#   Then edit the values below for your server.
# ─────────────────────────────────────────────────────

MONGO_URL=mongodb://localhost:27017
DB_NAME=welltrack

# Generate a strong random string — e.g.:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-this-to-a-long-random-string

# Set to false when running over plain HTTP (no SSL).
# Set to true (or remove) when running over HTTPS.
COOKIE_SECURE=false

# Google OAuth — school portal (leave blank if disabled in Settings)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://192.168.1.9/welltrack/api/auth/callback

# Google OAuth — Super Admin portal
# Reuses GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET above (same Google Cloud project, same server).
# Add this URI as an authorised redirect in your Google Cloud Console OAuth client:
#   https://welltrack.com.au/api/superadmin/auth/google/callback
SA_GOOGLE_REDIRECT_URI=https://welltrack.com.au/api/superadmin/auth/google/callback

FRONTEND_URL=http://192.168.1.9/welltrack

# Comma-separated allowed origins for CORS
# Include both IP and domain if you use both
ALLOWED_ORIGINS=http://192.168.1.9,https://apps.mooroopna.vic.edu.au

# Ollama local AI (leave defaults if running Ollama on the same machine)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
