# ─────────────────────────────────────────────────────
# WellTrack — Frontend Environment Template
#
# INSTRUCTIONS:
#   cp frontend/env.template frontend/.env
#   Then edit the values below for your server.
# ─────────────────────────────────────────────────────

# Your server's address — no trailing slash
# Use whichever matches your setup:
#   http://192.168.1.9
#   https://apps.mooroopna.vic.edu.au
REACT_APP_BACKEND_URL=http://192.168.1.9

# The subpath the app is served from (must match your Nginx config)
REACT_APP_BASE_PATH=/welltrack

# Asset base path — MUST be the same as REACT_APP_BASE_PATH
# Tells the browser to load JS/CSS from /welltrack/static/... instead of /static/...
PUBLIC_URL=/welltrack
